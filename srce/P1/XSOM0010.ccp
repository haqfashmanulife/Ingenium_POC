PF 13 *----------------------------
PF 13  7800-GET-MONTH-ABBREVIATIONS.
PF 13 *----------------------------

PF 13      IF NOT WGLOB-DT-FRMT-DDMMMYYYY
PF 13         GO TO 7800-GET-MONTH-ABBREVIATIONS-X
PF 13      END-IF.

PF 13 *  RETRIEVE MONTH ABBREVIATIONS FOR DATE TYPE
PF 13      PERFORM  2490-1000-BUILD-PARM-INFO
PF 13          THRU 2490-1000-BUILD-PARM-INFO-X.

PF 13      MOVE 'XSDU1640'                TO L2490-TXT-SRC-ID.
PF 13      MOVE '00001'                   TO L2490-TXT-SRC-REF-ID.

PF 13      PERFORM  2490-1000-RETRIEVE-TEXT
PF 13          THRU 2490-1000-RETRIEVE-TEXT-X.

PF 13      IF L2490-RETRN-OK
PF 13          MOVE L2490-TXT-STR-TXT     TO WGLOB-MOS-ABBR-TXT
PF 13      ELSE
PF 13          MOVE 'JANFEBMARAPRMAYJUNJULAUGSEPOCTNOVDEC'
PF 13                                     TO WGLOB-MOS-ABBR-TXT
PF 13      END-IF.

PF 13  7800-GET-MONTH-ABBREVIATIONS-X.
PF 13      EXIT.
PF 13 /
PF 1.2*-----------------------
PF 1.2 8000-PROCESS-NO-SESSION.
PF 1.2*-----------------------
PF 1.2*
PF 13      PERFORM  7800-GET-MONTH-ABBREVIATIONS
PF 13          THRU 7800-GET-MONTH-ABBREVIATIONS-X.
PF 13 *  CHECK THAT THE REQUESTED BUSINESS FUNCTIONS EXIST IN BPFS AND
PF 13 *  THAT THE USER HAS ACCESS TO ALL OF THEM.

PF 1.2*  CHECK THAT THE REQUESTED BUSINESS FUNCTION EXISTS
PF 1.2*
PF 13 *    MOVE LSIR-MSG-AREA(1:11)      TO WS-MIR-CONTROL-FIELDS.
PF 13 *    MOVE WS-MIR-BUS-FCN-ID        TO WBFCN-BUS-FCN-ID.
PF 13 *
PF 13 *    PERFORM  BFCN-1000-READ
PF 13 *        THRU BFCN-1000-READ-X.
PF 13 *
PF 13 *    IF  WBFCN-IO-NOT-FOUND
PF 13 *        SET  LSIR-SERVER-ERROR    TO  TRUE
PF 13 *        GO TO  8000-PROCESS-NO-SESSION-X
PF 13 *    END-IF.
PF 1.2*
PF 1.2*    GET DEFAULT COMPANY ID
PF 1.2*
PF 13 *    MOVE WS-DEFAULT-EDIT-LANG-CD  TO L0012-ETBL-LANG-CD.
PF 13 *    PERFORM  0012-1000-GET-DEFAULT-CO-ID
PF 13 *        THRU 0012-1000-GET-DEFAULT-CO-ID-X.
PF 13 *
PF 13 *    MOVE L0012-ETBL-VALU-ID       TO LSIR-CO-ID.
PF 13 *    MOVE L0012-ETBL-VALU-ID       TO WGLOB-COMPANY-CODE.
PF 1.2*
PF 1.2* RETRIEVE THE APPL RECORD FOR THE COMPANY TO SET THE EDIT LANG
PF 1.2*
PF 1.2     PERFORM  APPL-1000-READ
PF 1.2         THRU APPL-1000-READ-X.
PF 1.2     IF WAPPL-IO-OK
PF 1.2         MOVE RAPPL-APPL-EDIT-LANG-CD  TO WGLOB-EDIT-LANG
PF 1.2     ELSE
PF 1.2         MOVE WS-DEFAULT-EDIT-LANG-CD  TO WGLOB-EDIT-LANG
PF 1.2     END-IF.
PF 1.2*
PF 13      PERFORM  4050-VALIDATE-MIR-QTY
PF 13          THRU 4050-VALIDATE-MIR-QTY-X.
PF 13 *
PF 1.2*  THIS PROCESS DOES NOT PERFORM A USES LOOKUP.  TO ENSURE THAT
PF 1.2*  THERE IS NO CONFUSION WITH USES, IT WILL BE INITIALIZED TO LOW
PF 1.2*  VALUES.
PF 1.2
PF 1.2     MOVE LOW-VALUE TO RUSES-REC-INFO.

PF 13 *    PERFORM LOGIN FUNCTION - FIRST FUNCTION ON THE SINGLE P-STEP
           PERFORM  8200-P-STEP-LOGIN
               THRU 8200-P-STEP-LOGIN-X.

PF 13 *    VALIDATE RETURN CODE.
PF 13      IF NOT LSIR-RETURN-OK
PF 13          SET LSIR-SECURITY-CHECK-FAILED TO TRUE
PF 13          GO TO 8000-PROCESS-NO-SESSION-X
PF 13      END-IF.
PF 13
PF 13      PERFORM  4090-UPDATE-MIR-COORDINATE
PF 13          THRU 4090-UPDATE-MIR-COORDINATE-X.
PF 13
PF 13 *    VALIDATE ACCESS TO ALL REMAINING P-STEPS ASSUMING THAT LOGIN
PF 13 *    WAS SUCCESSFUL.

PF 13      MOVE WS-MIR-START-COORDINATE TO WS-MIR-HOLD-COORDINATE.
PF 13      MOVE 2                     TO WS-SUB.
PF 13      PERFORM  8100-VALIDATE-AGAINST-BPFS
PF 13          THRU 8100-VALIDATE-AGAINST-BPFS-X
PF 13         UNTIL WS-MIR-PROCESSING-COMPLETE
PF 13            OR NOT LSIR-RETURN-OK
PF 13            OR WS-SUB > LSIR-MIR-QTY.

PF 13 *    PERFORM  4000-PROCESS-TRANSACTION
PF 13 *        THRU 4000-PROCESS-TRANSACTION-X.
PF 1.2*
PF 1.2*  WHEN A NON-ZERO RETURN CODE IS RECEIVED, THEN CHECK TO SEE
PF 1.2*  IF THAT RETURN CODE WAS CAUSED BY THE SECURITY CHECK - UPDATE
PF 1.2*  THE LSIR-RETURN-CODE TO INDICATE SECURITY CHECK FAILED.
PF 1.2     IF NOT LSIR-RETURN-OK
PF 1.2         MOVE LSIR-MSG-AREA(1:11) TO WS-MIR-CONTROL-FIELDS
PF 1.2         IF  WS-MIR-RETRN-EDIT-ERROR
PF 1.2             SET LSIR-SECURITY-CHECK-FAILED TO TRUE
PF 1.2         END-IF
PF 1.2     END-IF.
PF 13
PF 13 *    PROCESS ALL P-STEPS AFTER THE FIRST LOGIN P-STEP
PF 13      MOVE WS-MIR-HOLD-COORDINATE TO WS-MIR-START-COORDINATE.
PF 13      PERFORM  4070-MOVE-NEXT-MIR-TO-WS
PF 13          THRU 4070-MOVE-NEXT-MIR-TO-WS-X
PF 13
PF 13      PERFORM  4100-PROCESS-ONE-MIR
PF 13          THRU 4100-PROCESS-ONE-MIR-X
PF 13       VARYING WS-SUB FROM 2 BY 1
PF 13         UNTIL WS-MIR-PROCESSING-COMPLETE
PF 13          OR NOT LSIR-RETURN-OK
PF 13          OR WS-SUB > LSIR-MIR-QTY.
                
SESCAP     MOVE WGLOB-USER-SESN-ID         TO WUSES-USER-SESN-ID
SESCAP     PERFORM  USES-1000-READ-FOR-UPDATE
SESCAP         THRU USES-1000-READ-FOR-UPDATE-X.
SESCAP     IF  WUSES-IO-OK
SESCAP         PERFORM  USES-2000-REWRITE
SESCAP             THRU USES-2000-REWRITE-X
SESCAP     END-IF.

PF 1.2*
PF 1.2*  CLEANUP FUNCTIONALITY
PF 1.2*
PF 1.2     MOVE WGLOB-USER-ID          TO L8095-USER-ID.
PF 1.2     PERFORM  8095-2000-CLEANUP-TWRK
PF 1.2         THRU 8095-2000-CLEANUP-TWRK-X.
PF 1.2
PF 1.2 8000-PROCESS-NO-SESSION-X.
PF 1.2     EXIT.
PF 13 *--------------------------
PF 13  8100-VALIDATE-AGAINST-BPFS.
PF 13 *--------------------------
PF 13
PF 13      MOVE WS-MIR-BUS-FCN-ID          TO LSIR-BPF-ID.
PF 13
PF 13      PERFORM  7300-READ-BPFS-REC
PF 13          THRU 7300-READ-BPFS-REC-X.
PF 13
PF 13      ADD  WS-MIR-LEN                 TO WS-MIR-START-COORDINATE.
PF 13      MOVE LSIR-MSG-AREA(WS-MIR-START-COORDINATE:11)
PF 13                                      TO WS-MIR-CONTROL-FIELDS.
PF 13      ADD +1                          TO WS-SUB.
PF 13
PF 13  8100-VALIDATE-AGAINST-BPFS-X.
PF 13      EXIT.

PF 13 *-----------------
PF 13  8200-P-STEP-LOGIN.
PF 13 *-----------------
PF 13
PF 13      PERFORM  4060-INIT-MIR-COORDINATES
PF 13          THRU 4060-INIT-MIR-COORDINATES-X.
PF 13      PERFORM  4070-MOVE-NEXT-MIR-TO-WS
PF 13          THRU 4070-MOVE-NEXT-MIR-TO-WS-X.
PF 13      PERFORM  7400-READ-BFCN-REC
PF 13          THRU 7400-READ-BFCN-REC-X.
PF 13
PF 13      IF NOT LSIR-RETURN-OK
PF 13          GO TO 8200-P-STEP-LOGIN-X
PF 13      END-IF.
PF 13
PF 13      PERFORM  4120-CALL-PROCESS-DRIVER
PF 13          THRU 4120-CALL-PROCESS-DRIVER-X.
PF 13
PF 13      PERFORM  4080-MOVE-WS-TO-MIR
PF 13          THRU 4080-MOVE-WS-TO-MIR-X.
PF 13
PF 13      PERFORM  4130-SET-LSIR-RETURN-CD
PF 13          THRU 4130-SET-LSIR-RETURN-CD-X.
PF 13
PF 13  8200-P-STEP-LOGIN-X.
PF 13      EXIT.

      /
      *------------------
       9000-PROCESS-ABEND.
      *------------------

           IF WGLOB-ERROR-CD-VALID
               NEXT SENTENCE
           ELSE
               SET  WGLOB-CICS-ERROR       TO TRUE
               MOVE SPACES                 TO WGLOB-IO-COMMAND
               MOVE SPACES                 TO WGLOB-OPTM-SQL-STAT-CD
               MOVE SPACES                 TO WGLOB-OPTM-SQL-REQIR
               MOVE SPACES                 TO WGLOB-OPTM-SQL-EXEC
               MOVE ZERO                   TO WGLOB-SEQ-FILE-STATUS
               MOVE ZERO                   TO WGLOB-SQLCODE
               MOVE SPACES                 TO WGLOB-ERROR-DESC-TXT
           END-IF.

           EXEC CICS LINK
                PROGRAM('XSOM0030')
                COMMAREA (WGLOB-GLOBAL-AREA)
                LENGTH   (WGLOB-GLOBAL-LEN)
           END-EXEC.

           SET LSIR-SERVER-ERROR           TO TRUE.
           MOVE WGLOB-ABEND-CD             TO WGLOB-MSG-PARM (1).
           IF WGLOB-SQL-ERROR
               MOVE WGLOB-SQLCODE          TO WS-DISPLAY-S7-0
               MOVE WS-DISPLAY-S7-0        TO WGLOB-MSG-PARM (2)
      *MSG: SERVER REQUEST ABENDED WITH @1, SQLCODE: @2
               MOVE 'XS00100005'           TO WGLOB-MSG-REF-INFO
           ELSE
      *MSG: SERVER REQUEST ABENDED WITH @1
               MOVE 'XS00100006'           TO WGLOB-MSG-REF-INFO
           END-IF.

           PERFORM  0260-2000-GET-MESSAGE
               THRU 0260-2000-GET-MESSAGE-X.
           MOVE WGLOB-MSG-TXT              TO LSIR-USER-MSG-TEXT-T (01).
           MOVE 1                          TO LSIR-ERROR-MSG-LINES-USED.
PF 13      MOVE WGLOB-MSG-SEVRTY-CD   TO LSIR-USER-MSG-SEVRTY-CD-T (01).

           IF WGLOB-SQL-ERROR
               MOVE WGLOB-ERROR-DESC-TXT   TO LSIR-USER-MSG-TEXT-T (02)
               ADD +1                      TO LSIR-ERROR-MSG-LINES-USED
PF 13          MOVE '1'               TO LSIR-USER-MSG-SEVRTY-CD-T (02)
           END-IF.

           MOVE  LSIR-PARM-AREA             TO  DFHCOMMAREA.
            
01AR01     IF WENVT-MICROFOCUS-CICS
NTDEV          PERFORM  0035-1000-COMMIT
NTDEV              THRU 0035-1000-COMMIT-X
01AR01     END-IF.

           EXEC CICS
               RETURN
           END-EXEC.
      *
       9000-PROCESS-ABEND-X.
           EXIT.
      /
PIRAEX*------------------------
PIRAEX 9600-OUTPUT-USAU-RECORD.
PIRAEX*------------------------
PIRAEX
PIRAEX     MOVE WGLOB-USER-ID             TO WUSAU-USER-ID.
PIRAEX     MOVE WGLOB-SYSTEM-DATE-INT     TO WUSAU-LOGIN-FAIL-DT.
PIRAEX     MOVE WGLOB-SYSTEM-TIME         TO WS-TIME-N.
PIRAEX     MOVE WS-TIME                   TO WUSAU-LOGIN-FAIL-TIME.
PIRAEX
PIRAEX     PERFORM  USAU-1000-CREATE
PIRAEX         THRU USAU-1000-CREATE-X.
PIRAEX
PIRAEX     MOVE 'XSOM0010'         TO L2490-TXT-SRC-ID.
PIRAEX     MOVE WS-TXT-SRC-REF-ID  TO L2490-TXT-SRC-REF-ID.
PIRAEX
PIRAEX     PERFORM  2490-1000-RETRIEVE-TEXT
PIRAEX         THRU 2490-1000-RETRIEVE-TEXT-X.
PIRAEX
PIRAEX     MOVE L2490-TXT-STR-TXT  TO RUSAU-LOGIN-FAIL-MSG-TXT.
PIRAEX
PIRAEX     PERFORM  USAU-1000-WRITE
PIRAEX         THRU USAU-1000-WRITE-X.
PIRAEX
PIRAEX 9600-OUTPUT-USAU-RECORD-X.
PIRAEX     EXIT.
PIRAEX/
      ****************************************************************
      * PROCESSING COPYBOOKS                                         *
      ****************************************************************

       COPY XCCP0030.

      ****************************************************************
      *  LINKAGE COPYBOOKS                                           *
      ****************************************************************

       COPY XCCL0012.
NTDEV  COPY XCPL0035.
       COPY XCCL0260.
       COPY XCPL0280.
       COPY XCPL1580.
       COPY XCCL1610.
       COPY XCCL1611.
       COPY XCPL1640.
PF 13  COPY XCPS2490.
PF 13  COPY XCCL2490.
       COPY XCCL8095.

      ****************************************************************
      *  FILE I/O PROCESS MODULES                                    *
      ****************************************************************

       COPY XCPNAPPL.

       COPY XCPNBFCN.
       COPY XCPNBPFL.
       COPY XCPNBPFS.

       COPY XCPNUSCL.
PF 13 *COPY XCPNUSEC.
       COPY XCPNUSES.
SESCAP COPY XCPUUSES.
PIRAEX COPY CCPAUSAU.
PIRAEX COPY CCPCUSAU.
      /
      *****************************************************************
      **                 END OF PROGRAM XSOM0010                     **
      *****************************************************************
