       4100-INIT-OCF-TITLES.
      *---------------------

           MOVE WS-COMPANY-NAME         TO L0040-COMPANY-NAME.
           MOVE ZERO                    TO L0040-ERROR-CNT.

           MOVE SPACES                  TO WHDG-LINE-2.
           MOVE WPGWS-CRNT-PGM-ID       TO WHDG-PROGRAM-ID.

      *TEXT: LINC PROCESSING EXTRACT - MESSAGES AND CONTROL TOTALS
           MOVE '00009'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO L0040-PROGRAM-DESC.

      **** GET THE SYSTEM ID FOR THE HEADING
           MOVE 'XS00000145'            TO WGLOB-MSG-REF-INFO.
           PERFORM  0260-2000-GET-MESSAGE
               THRU 0260-2000-GET-MESSAGE-X.
           MOVE WGLOB-MSG-TXT           TO L0040-SYSTEM-ID.
           MOVE WGLOB-MSG-TXT           TO WHDG-SYSTEM-ID.

      **** GET THE DETAIL HEADINGS 'RUN MESSAGES'
           MOVE 'XS00000153'            TO WGLOB-MSG-REF-INFO.
           PERFORM  0260-2000-GET-MESSAGE
               THRU 0260-2000-GET-MESSAGE-X.
           MOVE WGLOB-MSG-TXT           TO L0040-HDG-LINE-3.

           MOVE SPACES                  TO L0040-SBSDRY-CO-NAME.

           PERFORM  0040-1000-INIT-TITLE
               THRU 0040-1000-INIT-TITLE-X.

       4100-INIT-OCF-TITLES-X.
           EXIT.
      /
      *--------------------------
       4200-INIT-DETAIL-HEADINGS.
      *--------------------------

      *  INITIALIZE PARMATERS FOR TEXT RETRIEVAL MODULE
           PERFORM  2490-1000-BUILD-PARM-INFO
               THRU 2490-1000-BUILD-PARM-INFO-X.
M119DM     MOVE 'NSBM9075'              TO L2490-TXT-SRC-ID.

      **** MOVE DATE TO HEADING
           MOVE WGLOB-SYSTEM-DATE-INT   TO L1640-INTERNAL-DATE.
           PERFORM  1640-2000-INTERNAL-TO-EXT
               THRU 1640-2000-INTERNAL-TO-EXT-X.
           MOVE L1640-EXTERNAL-DATE     TO WHDG-DATE.

      **** MOVE TIME TO HEADING
           MOVE WGLOB-SYSTEM-TIME       TO WTIME-EDIT-TIME.
           PERFORM  TIME-1000-REFORMAT
               THRU TIME-1000-REFORMAT-X.
           MOVE WTIME-DISPLAY-TIME      TO WHDG-TIME.

      **** SET UP HEADING CONTANTS - DATE:, TIME:, PAGE NO:
           PERFORM  HDG-1000-INIT-CONSTANTS
               THRU HDG-1000-INIT-CONSTANTS-X.
           PERFORM  HDG-2000-INIT-SBSDRY-CO
               THRU HDG-2000-INIT-SBSDRY-CO-X.

      *TEXT: LINC INTERFACE ERROR AND STATISTICS REPORT
           MOVE '00005'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-REPORT-TITLE-1.
           MOVE L2490-TXT-STR-TXT       TO WHDG-REPORT-TITLE.

      **** GET REPORT WS-HEADING-1
           MOVE '00006'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-HEADING-1.

      **** GET REPORT WS-HEADING-2
           MOVE '00007'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-HEADING-2.

      *TEXT: TOTALS
           MOVE '00008'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-DF1-TOTAL-TEXT.

       4200-INIT-DETAIL-HEADINGS-X.
           EXIT.
      /
      *-------------------------
       4300-WRITE-REPORT-DETAIL.
      *-------------------------

           ADD +1                       TO WS-LINE-CNTR.
           IF  WS-LINE-CNTR > WS-MAX-LINE-CNTR
               PERFORM  3500-WRITE-HEADINGS
                   THRU 3500-WRITE-HEADINGS-X
           END-IF.

           MOVE +1                      TO WPRT1-NUMBER-LINES.
           MOVE WS-DETAIL-LINE          TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.

       4300-WRITE-REPORT-DETAIL-X.
           EXIT.
