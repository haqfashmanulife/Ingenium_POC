P00120     PERFORM  LINC-1000-READ
P00120         THRU LINC-1000-READ-X.
M119NB     IF  WLINC-IO-OK
M119NB         SET  WS-LINC-EXISTS      TO TRUE
M119NB     ELSE
M119NB         SET  WS-LINC-EXISTS-NO   TO TRUE
M119NB     END-IF.
M119NB             
M119NB     IF  WS-LINC-EXISTS
M119DM*M119NB         IF  RLTRN-LTRN-REC-TYP-UA-PP
M119DM         IF  RLCDM-LCDM-REC-TYP-UA-PP
M119NB             PERFORM  LINC-1000-READ-FOR-UPDATE
M119NB                 THRU LINC-1000-READ-FOR-UPDATE-X
M119NB         ELSE
M119NB             GO TO 2500-WRITE-TLINC-X
M119NB         END-IF
M119NB     ELSE 
M119NB         PERFORM  LINC-1000-CREATE
M119NB             THRU LINC-1000-CREATE-X
M119NB     END-IF.
M119NB
M119NB*P00120     IF  WLINC-IO-OK
M119NB*P00120         GO TO 2500-WRITE-TLINC-X
M119NB*P00120     END-IF
M119NB*P00120
M119NB*P00120     PERFORM  LINC-1000-CREATE
M119NB*P00120         THRU LINC-1000-CREATE-X.
M119NB*P00120
M119NB     PERFORM  2600-CALC-INFC-BNFT-AMTS
M119NB         THRU 2600-CALC-INFC-BNFT-AMTS-X.
M119NB
M119NB     MOVE  WS-INFC-LIFE-DB-FACE-AMT TO  
M119NB                                RLINC-INFC-LIFE-DB-FACE-AMT.
M119NB     MOVE  WS-INFC-HOSP-BNFT-AMT    TO  
M119NB                                RLINC-INFC-HOSP-BNFT-AMT.
M119NB     IF  WS-LINC-EXISTS
M119NB         PERFORM  LINC-2000-REWRITE
M119NB             THRU LINC-2000-REWRITE-X
M119NB     ELSE
M119NB         PERFORM  LINC-1000-WRITE
M119NB             THRU LINC-1000-WRITE-X
M119NB     END-IF.
M119NB
M119NB*P00120     PERFORM  LINC-1000-WRITE
M119NB*P00120         THRU LINC-1000-WRITE-X.
P00120
P00120 2500-WRITE-TLINC-X.
P00120     EXIT.
      /
M119NB*------------------------
M119NB 2600-CALC-INFC-BNFT-AMTS.
M119NB*------------------------
M119NB
M119NB     MOVE ZEROS                     TO WS-TOT-LIFE-FACE-AMT.
M119NB     MOVE ZEROS                     TO WS-TOT-LIFE-ADB-FACE-AMT.
M119NB     MOVE ZEROS                     TO WS-INFC-HOSP-BNFT-AMT.
M119NB     MOVE ZEROS                     TO WS-INFC-LIFE-DB-FACE-AMT.
M119NB
M119NB* PROCESS COVERAGE AMOUNTS FOR THIS INSURED
M119NB* NOTE: CCLI IS AN ALTERNATE INDEX FOR CVGC
M119NB
M119NB     MOVE LOW-VALUES                TO WCCLI-KEY.
M119DM     MOVE RLCDM-INSRD-CLI-ID        TO WCCLI-INSRD-CLI-ID.
M119DM*M119NB     MOVE RLTRN-INSRD-CLI-ID        TO WCCLI-INSRD-CLI-ID.
M119NB     MOVE RPOL-POL-ID               TO WCCLI-POL-ID.
M119NB
M119NB     MOVE HIGH-VALUES               TO WCCLI-ENDBR-KEY.
M119DM     MOVE RLCDM-INSRD-CLI-ID        TO WCCLI-ENDBR-INSRD-CLI-ID.
M119DM*M119NB     MOVE RLTRN-INSRD-CLI-ID        TO WCCLI-ENDBR-INSRD-CLI-ID.
M119NB     MOVE RPOL-POL-ID               TO WCCLI-ENDBR-POL-ID.
M119NB
M119NB     PERFORM  CCLI-1000-BROWSE
M119NB         THRU CCLI-1000-BROWSE-X.
M119NB
M119NB     PERFORM  CCLI-2000-READ-NEXT
M119NB         THRU CCLI-2000-READ-NEXT-X.
M119NB
M119NB     PERFORM  2610-PRCES-INFC-CVGS
M119NB         THRU 2610-PRCES-INFC-CVGS-X
M119NB        UNTIL NOT WCCLI-IO-OK
M119NB           OR     WCCLI-IO-EOF

M119NB     PERFORM  CCLI-3000-END-BROWSE
M119NB         THRU CCLI-3000-END-BROWSE-X.
M119NB
M119NB     COMPUTE WS-INFC-LIFE-DB-FACE-AMT = WS-TOT-LIFE-FACE-AMT
M119NB                                  + WS-TOT-LIFE-ADB-FACE-AMT.
M119NB
M119NB 2600-CALC-INFC-BNFT-AMTS-X.
M119NB     EXIT.
M119NB/
      *----------------------
       2610-PRCES-INFC-CVGS.
      *----------------------

M119NB* ACCUMULATE IN-FORCE COVERAGES ONLY FOR PIRA ADDITIONS FOR
M119NB*INSURED LESS THAN 15 YEARS.
M119NB     IF  (RLNCX-REC-TYP-UA-PP
M119NB     AND  WCVGS-CVG-STAT-IN-FORCE (RCVGC-CVG-NUM-N))
M119NB* ACCUMULATE LIFE COVERAGES
M119NB         IF  (WCVGS-CVG-INS-TYP-UL-INS-ONLY (RCVGC-CVG-NUM-N)
M119NB         OR  WCVGS-CVG-INS-TYP-TRAD (RCVGC-CVG-NUM-N))
M119NB         AND WCVGS-PLAN-BNFT-TYP-CD (RCVGC-CVG-NUM-N) = SPACES
M119NB* ADD THE PRESENT CONVERTED FACE AMOUNT FOR IPDD RIDERS
M119NB* INSTEAD OF COVERAGE FACE AMOUNT
M119NB* 
M119NB             IF  WCVGS-PLAN-IP (RCVGC-CVG-NUM-N)
M119NB                 ADD WCVGS-PRES-CNVR-FACE-AMT (RCVGC-CVG-NUM-N)
M119NB                  TO WS-TOT-LIFE-FACE-AMT
M119NB             ELSE
M119NB                 ADD WCVGS-CVG-FACE-AMT (RCVGC-CVG-NUM-N)
M119NB                  TO WS-TOT-LIFE-FACE-AMT
M119NB             END-IF
M119NB         END-IF

M119NB* ACCUMULATE ADB COVERAGES
M119NB         IF  WCVGS-PLAN-BNFT-INJURY (RCVGC-CVG-NUM-N) 
M119NB         OR  WCVGS-PLAN-BNFT-ACCDTH (RCVGC-CVG-NUM-N) 
M119NB             ADD WCVGS-CVG-FACE-AMT (RCVGC-CVG-NUM-N)
M119NB              TO WS-TOT-LIFE-ADB-FACE-AMT
M119NB         END-IF

      * TEST HEALTH COVERAGES
M119NB         IF  WCVGS-PLAN-BNFT-DISEA (RCVGC-CVG-NUM-N)
M119NB         OR  WCVGS-PLAN-BNFT-HOSP-ACC (RCVGC-CVG-NUM-N)
M119NB         OR  WCVGS-PLAN-BNFT-HOSP-DIS (RCVGC-CVG-NUM-N)
M119NB         OR  WCVGS-PLAN-BNFT-C-HOSP (RCVGC-CVG-NUM-N)
M119NB         OR  WCVGS-PLAN-BNFT-C-ADISEASE (RCVGC-CVG-NUM-N)
M119NB             ADD WCVGS-CVG-FACE-AMT (RCVGC-CVG-NUM-N)
M119NB              TO WS-INFC-HOSP-BNFT-AMT
M119NB         END-IF

M119NB     END-IF.

M119NB     PERFORM  CCLI-2000-READ-NEXT
M119NB         THRU CCLI-2000-READ-NEXT-X.

M119NB 2610-PRCES-INFC-CVGS-X.
M119NB     EXIT.
M119NB/
      *--------------------
       3500-WRITE-HEADINGS.
      *--------------------

           ADD 1                        TO WS-PAGE-CNTR.
           MOVE WS-PAGE-CNTR            TO WHDG-PAGE.
           MOVE SPACES                  TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-2000-WRITE
               THRU PRT1-2000-WRITE-X.
           MOVE +1                      TO WPRT1-NUMBER-LINES.
           MOVE WHDG-LINE-1             TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.
           MOVE +1                      TO WPRT1-NUMBER-LINES.
           MOVE WHDG-LINE-2             TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.
           MOVE +2                      TO WPRT1-NUMBER-LINES.
           MOVE WS-HEADING-1               TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.
           MOVE +1                      TO WPRT1-NUMBER-LINES.
           MOVE WS-HEADING-2               TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.
           MOVE +1                      TO WPRT1-NUMBER-LINES.
           MOVE SPACES                  TO RPRT1-SEQ-REC-INFO.
           PERFORM  PRT1-1000-WRITE
               THRU PRT1-1000-WRITE-X.
           MOVE 8                       TO WS-LINE-CNTR.

       3500-WRITE-HEADINGS-X.
           EXIT.
      /
      *--------------------
       3600-WRITE-FOOTINGS.
      *--------------------

      * WRITE BLANK LINE
           MOVE SPACES                  TO WS-DETAIL-LINE.
           PERFORM  4300-WRITE-REPORT-DETAIL
               THRU 4300-WRITE-REPORT-DETAIL-X.

      *TEXT: TOTAL RECORDS INPUT  =
           MOVE '00003'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-DF1-TOTAL-TEXT.
           MOVE WS-REC-CNTR-IN          TO WS-DF1-TOTAL-X.

           PERFORM  4300-WRITE-REPORT-DETAIL
               THRU 4300-WRITE-REPORT-DETAIL-X.

      *TEXT: TOTAL RECORDS OUTPUT =
           MOVE '00004'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-DF1-TOTAL-TEXT.
           MOVE WS-REC-CNTR-OUT         TO WS-DF1-TOTAL-X.

           PERFORM  4300-WRITE-REPORT-DETAIL
               THRU 4300-WRITE-REPORT-DETAIL-X.

      *TEXT: TOTAL ERROR RECORDS  =
           MOVE '00015'                 TO WS-TXT-SRC-REF-ID.
           PERFORM  4700-GET-TEXT-DESC
               THRU 4700-GET-TEXT-DESC-X.
           MOVE L2490-TXT-STR-TXT       TO WS-DF1-TOTAL-TEXT.
           MOVE WS-ERROR-RECORDS        TO WS-DF1-TOTAL-X.

           PERFORM  4300-WRITE-REPORT-DETAIL
               THRU 4300-WRITE-REPORT-DETAIL-X.

       3600-WRITE-FOOTINGS-X.
           EXIT.
      /
      *----------------------
       4000-INIT-FOR-COMPANY.
      *----------------------

           MOVE SPACES                  TO WHDG-LINE-1.

           PERFORM  0950-0000-INIT-PARM-INFO
               THRU 0950-0000-INIT-PARM-INFO-X.
           PERFORM  0950-1000-GET-COMPANY-NAME
               THRU 0950-1000-GET-COMPANY-NAME-X.

