      *--------------
       0000-MAINLINE.
      *--------------

           INITIALIZE L0005-OUTPUT-PARM-INFO.

           EVALUATE TRUE

              WHEN L0005-RQST-CONVERT-STRING
                   PERFORM  0005-1000-CONVERT-STRING
                       THRU 0005-1000-CONVERT-STRING-X

              WHEN L0005-RQST-CONVERT-NO-ACCENTS
                   PERFORM  0005-2000-CONVERT-NO-ACCENTS
                       THRU 0005-2000-CONVERT-NO-ACCENTS-X
MP306B
MP306B        WHEN L0005-RQST-CONVERT-UPPER-KANA                       
MP306B             PERFORM  0005-3000-CONVERT-UPPER-KANA
MP306B                THRU  0005-3000-CONVERT-UPPER-KANA-X
UYS110
UYS110        WHEN L0005-RQST-CONVERT-SNDMK-KANA
UYS110             PERFORM  0005-4000-CONVERT-SNDMK-KANA
UYS110                 THRU 0005-4000-CONVERT-SNDMK-KANA-X
UYS110
              WHEN OTHER
                   SET  L0005-RETRN-INVALID-REQUEST TO TRUE

           END-EVALUATE.

           GOBACK.

       0000-MAINLINE-X.
           EXIT.

      /
      *------------------------
       0005-1000-CONVERT-STRING.
      *------------------------

AP0002     IF  WGLOB-COUNTRY-JAPAN
AP0002     AND NOT L0005-FORCE-UPPER
AP0002         MOVE L0005-INPUT-STRING    TO L0005-OUTPUT-STRING
AP0002         GO TO 0005-1000-CONVERT-STRING-X
AP0002     END-IF.

           INITIALIZE                        W0005-INPUT-STRING.
           INITIALIZE                        W0005-OUTPUT-STRING.

           MOVE 1                         TO W0005-COL-IN-SUB.
           MOVE L0005-INPUT-STRING        TO W0005-STRING-UNCONVERTED.

           IF W0005-STRING-UNCONVERTED > SPACES
              CONTINUE
           ELSE
              GO TO 0005-1000-CONVERT-STRING-X
           END-IF.

      *    SET W0005-COL-OUT-SUB TO 2. THIS WILL CAUSE LOWER-CASE
      *    CHARACTERS WITH ACCENTS TO BE CONVERTED TO UPPER-CASE
      *    WHILE RETAINING THEIR ACCENTS.


           SET W0005-CONVERT-WITH-ACCENTS TO TRUE.

           PERFORM  0005-5000-CONVERT
               THRU 0005-5000-CONVERT-X.

           MOVE W0005-STRING-CONVERTED    TO L0005-OUTPUT-STRING.

       0005-1000-CONVERT-STRING-X.
           EXIT.
      /
      *-----------------------------
       0005-2000-CONVERT-NO-ACCENTS.
      *-----------------------------

AP0002     IF  WGLOB-COUNTRY-JAPAN
AP0002     AND NOT L0005-FORCE-UPPER
AP0002         MOVE L0005-INPUT-STRING    TO L0005-OUTPUT-STRING
AP0002         GO TO 0005-2000-CONVERT-NO-ACCENTS-X
AP0002     END-IF.

           INITIALIZE                        W0005-INPUT-STRING.
           INITIALIZE                        W0005-OUTPUT-STRING.

           MOVE 1                         TO W0005-COL-IN-SUB.
           MOVE L0005-INPUT-STRING        TO W0005-STRING-UNCONVERTED.

           IF W0005-STRING-UNCONVERTED > SPACES
              CONTINUE
           ELSE
              GO TO 0005-2000-CONVERT-NO-ACCENTS-X
           END-IF.

      *    SET W0005-COL-OUT-SUB = 3. THIS WILL CAUSE LOWER-CASE
      *    CHARACTERS WITH ACCENTS TO BE CONVERTED TO UPPER-CASE
      *    WHILE DROPPING THEIR ACCENTS.

           SET W0005-CONVERT-WITHOUT-ACCENTS TO TRUE.

           PERFORM  0005-5000-CONVERT
               THRU 0005-5000-CONVERT-X.

           MOVE W0005-STRING-CONVERTED      TO L0005-OUTPUT-STRING.

       0005-2000-CONVERT-NO-ACCENTS-X.
           EXIT.
      /
      *-----------------
       0005-5000-CONVERT.
      *-----------------

           PERFORM VARYING I FROM +1 BY +1
              UNTIL I > +132

              IF W0005-BYTE-UNCONVERTED (I) > SPACES
                 PERFORM  0005-5100-CONVERT-BYTE
                     THRU 0005-5100-CONVERT-BYTE-X
              ELSE
                 MOVE W0005-BYTE-UNCONVERTED (I)
                                          TO W0005-BYTE-CONVERTED (I)
              END-IF

           END-PERFORM.

       0005-5000-CONVERT-X.
           EXIT.
      /
      *-----------------------
       0005-5100-CONVERT-BYTE.
      *-----------------------

            PERFORM VARYING W0005-ROW-SUB FROM +1 BY +1
               UNTIL W0005-BYTE-UNCONVERTED (I) =
                     WS-CONVERSION-LETTER
                           (W0005-ROW-SUB, W0005-COL-IN-SUB)
                  OR W0005-ROW-SUB > WS-NUMBER-ENTRIES
015543         CONTINUE
            END-PERFORM.

            IF W0005-ROW-SUB > WS-NUMBER-ENTRIES
               MOVE W0005-BYTE-UNCONVERTED (I)
                                          TO W0005-BYTE-CONVERTED (I)
            ELSE
               MOVE WS-CONVERSION-LETTER
                          (W0005-ROW-SUB, W0005-COL-OUT-SUB)
                                          TO W0005-BYTE-CONVERTED (I)
            END-IF.

       0005-5100-CONVERT-BYTE-X.
           EXIT.


