012624*----------------------------
012624
012624     IF MIR-SECUR-CLAS-MAX-AMT = EBLCH-BLANK-FIELD-CHAR
012624         MOVE ZERO              TO MIR-SECUR-CLAS-MAX-AMT
012624     END-IF.
012624
012624     MOVE MIR-SECUR-CLAS-MAX-AMT   TO L0280-INPUT-DATA.
012624     MOVE 'N'                      TO L0280-SIGN-IND.
012624     MOVE +2                       TO L0280-PRECISION.
012624     MOVE LENGTH OF MIR-SECUR-CLAS-MAX-AMT
012624                                  TO L0280-INPUT-SIZE.
012624     COMPUTE L0280-LENGTH = L0280-INPUT-SIZE - 3.
012624     PERFORM  0280-1000-NUMERIC-EDIT
012624         THRU 0280-1000-NUMERIC-EDIT-X.
012624
012624     IF L0280-OK
012624         MOVE L0280-OUTPUT-DOLLAR
012624                                TO RUSCL-SECUR-CLAS-MAX-AMT
012624         PERFORM  0290-1000-BUILD-PARM-INFO
012624             THRU 0290-1000-BUILD-PARM-INFO-X
012624         COMPUTE L0290-INPUT-NUMBER = RUSCL-SECUR-CLAS-MAX-AMT
012624                                    * 100
012624         MOVE +2                TO L0290-PRECISION
012624         MOVE LENGTH OF MIR-SECUR-CLAS-MAX-AMT
012624                                TO L0290-MAX-OUT-LEN
012624         PERFORM  0290-1000-NUMERIC-FORMAT
012624             THRU 0290-1000-NUMERIC-FORMAT-X
012624         MOVE L0290-OUTPUT-DATA TO MIR-SECUR-CLAS-MAX-AMT
012624     ELSE
012624         MOVE 'XS01600008'      TO WGLOB-MSG-REF-INFO
012624         PERFORM  0260-1000-GENERATE-MESSAGE
012624             THRU 0260-1000-GENERATE-MESSAGE-X
012624     END-IF.
