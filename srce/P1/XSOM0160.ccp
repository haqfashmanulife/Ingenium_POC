012624     END-IF.
012624
012624     MOVE MIR-CTL-ACCT-ACCS-IND TO WS-CTL-ACCT-ACCS-IND.
012624     IF  WS-CTL-ACCT-ACCS-VALID
012624         MOVE MIR-CTL-ACCT-ACCS-IND
012624                                TO RUSCL-CTL-ACCT-ACCS-IND
012624     ELSE
012624* MSG: INVALID ACCOUNT ACCESS INDICATOR
012624          MOVE 'XS01600009'  TO WGLOB-MSG-REF-INFO
012624          PERFORM  0260-1000-GENERATE-MESSAGE
012624              THRU 0260-1000-GENERATE-MESSAGE-X
012624     END-IF.
012624
012624 2337-EDIT-CTL-ACCT-ACCS-IND-X.
012624     EXIT.
      /
SESCAP*-----------------------
SESCAP 2338-EDIT-SESN-CTL-IND.
SESCAP*-----------------------
SESCAP     IF MIR-SESN-CTL-IND = EBLCH-BLANK-FIELD-CHAR
SESCAP        MOVE 'N'                TO MIR-SESN-CTL-IND
SESCAP     END-IF.
SESCAP     MOVE MIR-SESN-CTL-IND TO WS-SESN-CTL-IND.
SESCAP     IF  WS-SESN-CTL-VALID
SESCAP         MOVE MIR-SESN-CTL-IND TO RUSCL-SESN-CTL-IND
SESCAP     ELSE
SESCAP* MSG: INVALID SESSION CONTROL INDICATOR
SESCAP         MOVE 'XS01600010'  TO WGLOB-MSG-REF-INFO
SESCAP         PERFORM  0260-1000-GENERATE-MESSAGE
SESCAP             THRU 0260-1000-GENERATE-MESSAGE-X
SESCAP     END-IF.
SESCAP 2338-EDIT-SESN-CTL-IND-X.
SESCAP     EXIT.
SESCAP*-----------------------
SESCAP 2339-EDIT-MAX-SESN-NUM.
SESCAP*-----------------------
SESCAP     IF MIR-MAX-SESN-NUM = EBLCH-BLANK-FIELD-CHAR
SESCAP         MOVE ZERO              TO MIR-MAX-SESN-NUM
SESCAP     END-IF.
SESCAP
SESCAP     MOVE MIR-MAX-SESN-NUM      TO L0280-INPUT-DATA.
SESCAP     MOVE 'N'                   TO L0280-SIGN-IND.
SESCAP     MOVE 5                     TO L0280-LENGTH.
SESCAP     MOVE 0                     TO L0280-PRECISION.
SESCAP     PERFORM  0280-1000-NUMERIC-EDIT
SESCAP         THRU 0280-1000-NUMERIC-EDIT-X.
SESCAP     IF L0280-OK
SESCAP         MOVE L0280-OUTPUT      TO WS-MAX-SESN-NUM
SESCAP         MOVE WS-MAX-SESN-NUM   TO RUSCL-MAX-SESN-NUM
SESCAP         MOVE RUSCL-MAX-SESN-NUM TO MIR-MAX-SESN-NUM
SESCAP     ELSE
SESCAP* MSG: INVALID MAXIMUM NUMBER OF SESSIONS
SESCAP         MOVE 'XS01600011'      TO WGLOB-MSG-REF-INFO
SESCAP         PERFORM  0260-1000-GENERATE-MESSAGE
SESCAP             THRU 0260-1000-GENERATE-MESSAGE-X
SESCAP         GO TO 2339-EDIT-MAX-SESN-NUM-X
SESCAP     END-IF.
SESCAP     IF WS-MAX-SESN-NUM < WS-MIN-MAX-SESN-NUM
SESCAP     OR WS-MAX-SESN-NUM > WS-MAX-MAX-SESN-NUM
SESCAP* MSG: MAXIMUM NUMBER OF SESSIONS OUT OF RANGE
SESCAP         MOVE 'XS01600012'      TO WGLOB-MSG-REF-INFO
SESCAP         PERFORM  0260-1000-GENERATE-MESSAGE
SESCAP             THRU 0260-1000-GENERATE-MESSAGE-X
SESCAP         GO TO 2339-EDIT-MAX-SESN-NUM-X
SESCAP     END-IF.
SESCAP 2339-EDIT-MAX-SESN-NUM-X.
SESCAP     EXIT.
      *--------------------
       2400-PROCESS-DELETE.
      *--------------------
      *
016221     PERFORM  2420-DELETE-EDIT              
016221         THRU 2420-DELETE-EDIT-X.
           
016221     IF  WGLOB-MSG-ERROR-SW > ZEROS
016221         GO TO  2400-PROCESS-DELETE-X
016221     END-IF.
           
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.

           PERFORM  USCL-1000-READ-FOR-UPDATE
               THRU USCL-1000-READ-FOR-UPDATE-X.

           IF  WUSCL-IO-OK
               CONTINUE
           ELSE
               MOVE WUSCL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000010'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.
      *

           IF  RUSCL-SECUR-USER-CTR > ZERO
               PERFORM  USCL-3000-UNLOCK
                   THRU USCL-3000-UNLOCK-X
               PERFORM  9200-MOVE-RECORD-TO-SCREEN
                   THRU 9200-MOVE-RECORD-TO-SCREEN-X
               MOVE 'XS01600004'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               GO TO 2400-PROCESS-DELETE-X
54-001     END-IF.

           PERFORM  USCL-1000-DELETE
               THRU USCL-1000-DELETE-X.
           MOVE 'XS00000011'          TO WGLOB-MSG-REF-INFO.
           PERFORM  0260-1000-GENERATE-MESSAGE
               THRU 0260-1000-GENERATE-MESSAGE-X.

           PERFORM  9100-BLANK-DATA-FIELDS
               THRU 9100-BLANK-DATA-FIELDS-X.

       2400-PROCESS-DELETE-X.
           EXIT.
      /
016221*----------------
016221 2420-DELETE-EDIT.
016221*----------------
       
016221     MOVE  LOW-VALUES        TO  WBPFS-KEY.
016221     MOVE HIGH-VALUES        TO  WBPFS-ENDBR-KEY.

016221     MOVE MIR-SECUR-CLAS-ID  TO WBPFS-SECUR-CLAS-ID.
016221     MOVE MIR-SECUR-CLAS-ID  TO WBPFS-ENDBR-SECUR-CLAS-ID.

016221     PERFORM  BPFS-1000-BROWSE            
016221         THRU BPFS-1000-BROWSE-X.

016221     IF  WBPFS-IO-OK
016221         PERFORM  BPFS-2000-READ-NEXT         
016221             THRU BPFS-2000-READ-NEXT-X
016221         IF  WBPFS-IO-OK
016221*MSG: PLEASE DELETE REFEREINTIAL RECORD(S) FIRST-
016221*     DELETE NOT PROCESSED
016221             MOVE 'XS01600007'      TO WGLOB-MSG-REF-INFO
016221             PERFORM  0260-1000-GENERATE-MESSAGE
016221                 THRU 0260-1000-GENERATE-MESSAGE-X
016221         END-IF
      
016221         PERFORM  BPFS-3000-END-BROWSE        
016221             THRU BPFS-3000-END-BROWSE-X
016221     END-IF.
016221 2420-DELETE-EDIT-X.
           EXIT.
      /
      *--------------------
       2500-PROCESS-LIST.
      *--------------------
      *
           MOVE SPACES                TO MIR-SECUR-CLAS-ID-G.
012624*    MOVE SPACES                TO MIR-MSG-SECUR-CLAS-CD-G.
012624     MOVE SPACES                TO MIR-SECUR-CLAS-UWG-AMT-G.
012624     MOVE SPACES                TO MIR-SECUR-CLAS-MAX-AMT-G.
012624     MOVE SPACES                TO MIR-CTL-ACCT-ACCS-IND-G.
           MOVE SPACES                TO MIR-SECUR-CNFD-ACCS-CD-G.
           MOVE SPACES                TO MIR-SECUR-USER-CTR-G.
012624*    MOVE SPACES                TO MIR-ETBL-DESC-TXT-G.
SESCAP     MOVE SPACES                TO MIR-SESN-CTL-IND-G.
SESCAP     MOVE SPACES                TO MIR-MAX-SESN-NUM-G.
      *
           MOVE LOW-VALUES            TO WUSCL-KEY.
           MOVE HIGH-VALUES           TO WUSCL-ENDBR-KEY.
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.
      *
           PERFORM  USCL-1000-BROWSE
               THRU USCL-1000-BROWSE-X.
      *
           IF  WUSCL-IO-EOF
53-064         MOVE 'XS00000034'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               GO TO 2500-PROCESS-LIST-X
           ELSE
               PERFORM  USCL-2000-READ-NEXT
                   THRU USCL-2000-READ-NEXT-X
               IF  WUSCL-IO-EOF
                  MOVE 'XS00000025'   TO WGLOB-MSG-REF-INFO
                  PERFORM  0260-1000-GENERATE-MESSAGE
                      THRU 0260-1000-GENERATE-MESSAGE-X
                  GO TO 2500-PROCESS-LIST-X
54-001         END-IF
54-001     END-IF.
      *
           PERFORM  2510-PROCESS-LIST-READ
557660         THRU 2510-PROCESS-LIST-READ-X
               VARYING WS-SUB FROM +1 BY +1
               UNTIL WS-SUB > WS-MAX-BROWSE-LINES
               OR    WUSCL-IO-EOF.

           IF  WUSCL-IO-EOF
               MOVE 'XS00000025'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
           ELSE
               MOVE 'XS00000014'      TO WGLOB-MSG-REF-INFO
53-064         SET WGLOB-MORE-DATA-EXISTS TO TRUE
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.

           PERFORM  USCL-3000-END-BROWSE
               THRU USCL-3000-END-BROWSE-X.
      *
       2500-PROCESS-LIST-X.
           EXIT.
      /
      *-------------------------
       2510-PROCESS-LIST-READ.
      *-------------------------
      *
           MOVE RUSCL-SECUR-CLAS-ID   TO MIR-SECUR-CLAS-ID-T (WS-SUB).
012624*    MOVE RUSCL-MSG-SECUR-CLAS-CD
012624*                            TO MIR-MSG-SECUR-CLAS-CD-T  (WS-SUB).
           MOVE RUSCL-SECUR-CNFD-ACCS-CD
                                   TO MIR-SECUR-CNFD-ACCS-CD-T (WS-SUB).
           MOVE RUSCL-SECUR-USER-CTR  TO MIR-SECUR-USER-CTR-T (WS-SUB).
012624     MOVE RUSCL-CTL-ACCT-ACCS-IND  TO MIR-CTL-ACCT-ACCS-IND-T
012624                                      (WS-SUB).
012624*    PERFORM  3000-GET-SEC-CLASS-DESC
012624*        THRU 3000-GET-SEC-CLASS-DESC-X
554712*    MOVE RUSCL-SECUR-DESC-TXT  TO MIR-ETBL-DESC-TXT-T (WS-SUB).
012624*    MOVE WS-SECUR-DESC-TXT     TO MIR-ETBL-DESC-TXT-T (WS-SUB).

012624     PERFORM  0290-1000-BUILD-PARM-INFO
012624         THRU 0290-1000-BUILD-PARM-INFO-X.
012624     COMPUTE L0290-INPUT-NUMBER =  RUSCL-SECUR-CLAS-UWG-AMT
012624                                *  100.
012624     MOVE 2                     TO L0290-PRECISION.
012624     MOVE LENGTH OF MIR-SECUR-CLAS-UWG-AMT
012624                                TO L0290-MAX-OUT-LEN.
012624     PERFORM  0290-1000-NUMERIC-FORMAT
012624         THRU 0290-1000-NUMERIC-FORMAT-X.
012624     MOVE L0290-OUTPUT-DATA TO MIR-SECUR-CLAS-UWG-AMT-T (WS-SUB).

012624     PERFORM  0290-1000-BUILD-PARM-INFO
012624         THRU 0290-1000-BUILD-PARM-INFO-X.
012624     COMPUTE L0290-INPUT-NUMBER =  RUSCL-SECUR-CLAS-MAX-AMT
012624                                *  100.
012624     MOVE 2                     TO L0290-PRECISION.
012624     MOVE LENGTH OF MIR-SECUR-CLAS-MAX-AMT
012624                                TO L0290-MAX-OUT-LEN.
012624     PERFORM  0290-1000-NUMERIC-FORMAT
012624         THRU 0290-1000-NUMERIC-FORMAT-X.
012624     MOVE L0290-OUTPUT-DATA TO MIR-SECUR-CLAS-MAX-AMT-T (WS-SUB).
SESCAP     MOVE RUSCL-SESN-CTL-IND TO MIR-SESN-CTL-IND-T (WS-SUB).
SESCAP     MOVE RUSCL-MAX-SESN-NUM    TO  MIR-MAX-SESN-NUM-T (WS-SUB).

           PERFORM  USCL-2000-READ-NEXT
               THRU USCL-2000-READ-NEXT-X.

           IF  WS-SUB = WS-MAX-BROWSE-LINES
               IF  WUSCL-IO-OK
                   MOVE RUSCL-SECUR-CLAS-ID
                                      TO MIR-SECUR-CLAS-ID
54-001        END-IF
54-001     END-IF.
      *
       2510-PROCESS-LIST-READ-X.
           EXIT.
      /
012624*-----------------------
012624*3000-GET-SEC-CLASS-DESC.
012624*-----------------------
012624*
012624*    READ 'XTAB' TABLE RECORD TYPE 'USCL' KEYED ON THE
012624*    SECURITY CLASS ID TO GET THE SECURITY CALSS
012624*    DESCRIPTION FOR DISPLAY
012624*
012624*    MOVE RUSCL-SECUR-CLAS-ID   TO WXTAB-ETBL-VALU-ID.
012624*
012624*    PERFORM  USCL-2000-DESC
012624*        THRU USCL-2000-DESC-X.
012624*
012624*    IF WXTAB-IO-OK
012624*       MOVE RXTAB-ETBL-DESC-TXT              TO WS-SECUR-DESC-TXT
012624*    ELSE
012624*       MOVE SPACES             TO WS-SECUR-DESC-TXT
012624*    END-IF.
012624*
012624*3000-GET-SEC-CLASS-DESC-X.
012624*    EXIT.
      /
      *-----------------------
       9100-BLANK-DATA-FIELDS.
      *-----------------------
      *
012624*    MOVE SPACES                TO MIR-MSG-SECUR-CLAS-CD.
           MOVE SPACES                TO MIR-SECUR-CNFD-ACCS-CD.
           MOVE SPACES                TO MIR-SECUR-LVL-CD.
012624*    MOVE SPACES                TO MIR-SECUR-APPL-USE-TXT.
012624     MOVE ZEROS                 TO MIR-SECUR-CLAS-UWG-AMT.
012624     MOVE ZEROS                 TO MIR-SECUR-CLAS-MAX-AMT.
012624     MOVE 'N'                   TO MIR-CTL-ACCT-ACCS-IND.
           MOVE SPACES                TO MIR-SECUR-USER-CTR.
012624*    MOVE SPACES                TO MIR-ETBL-DESC-TXT.
SESCAP     MOVE 'N'                   TO MIR-SESN-CTL-IND.
SESCAP     MOVE ZEROS                 TO MIR-MAX-SESN-NUM.
      *
       9100-BLANK-DATA-FIELDS-X.
           EXIT.
      /
      *---------------------------
       9200-MOVE-RECORD-TO-SCREEN.
      *---------------------------
      *
           MOVE RUSCL-SECUR-CLAS-ID   TO MIR-SECUR-CLAS-ID.
012624*    MOVE RUSCL-MSG-SECUR-CLAS-CD
012624*                               TO MIR-MSG-SECUR-CLAS-CD.
           MOVE RUSCL-SECUR-CNFD-ACCS-CD
                                      TO MIR-SECUR-CNFD-ACCS-CD.
           MOVE RUSCL-SECUR-LVL-CD    TO MIR-SECUR-LVL-CD.
012624     MOVE RUSCL-CTL-ACCT-ACCS-IND
012624                                TO MIR-CTL-ACCT-ACCS-IND.
557659*    MOVE RUSCL-SECUR-APPL-DEFN-CD TO MIR-SECUR-APPL-USE-TXT.
012624*    MOVE RUSCL-SECUR-APPL-USE-TXT
012624*                               TO MIR-SECUR-APPL-USE-TXT.
012624     PERFORM  0290-1000-BUILD-PARM-INFO
012624         THRU 0290-1000-BUILD-PARM-INFO-X.
012624     COMPUTE L0290-INPUT-NUMBER = RUSCL-SECUR-CLAS-UWG-AMT
012624                                * 100.
012624     MOVE 2                     TO  L0290-PRECISION.
012624     MOVE LENGTH OF MIR-SECUR-CLAS-UWG-AMT TO L0290-MAX-OUT-LEN.
012624     PERFORM  0290-1000-NUMERIC-FORMAT
012624         THRU 0290-1000-NUMERIC-FORMAT-X.
012624     MOVE L0290-OUTPUT-DATA     TO  MIR-SECUR-CLAS-UWG-AMT.
012624     PERFORM  0290-1000-BUILD-PARM-INFO
012624         THRU 0290-1000-BUILD-PARM-INFO-X.
012624     COMPUTE L0290-INPUT-NUMBER = RUSCL-SECUR-CLAS-MAX-AMT
012624                                * 100.
012624     MOVE 2                     TO  L0290-PRECISION.
012624     MOVE LENGTH OF MIR-SECUR-CLAS-MAX-AMT TO L0290-MAX-OUT-LEN.
012624     PERFORM  0290-1000-NUMERIC-FORMAT
012624         THRU 0290-1000-NUMERIC-FORMAT-X.
012624     MOVE L0290-OUTPUT-DATA     TO  MIR-SECUR-CLAS-MAX-AMT.
           MOVE RUSCL-SECUR-USER-CTR  TO MIR-SECUR-USER-CTR.
012624*    PERFORM  3000-GET-SEC-CLASS-DESC
012624*        THRU 3000-GET-SEC-CLASS-DESC-X
012624*    MOVE RUSCL-SECUR-DESC-TXT     TO MIR-ETBL-DESC-TXT.
012624*    MOVE WS-SECUR-DESC-TXT     TO MIR-ETBL-DESC-TXT.
      *
SESCAP     MOVE RUSCL-SESN-CTL-IND TO MIR-SESN-CTL-IND.
SESCAP*    PERFORM  0290-1000-BUILD-PARM-INFO
SESCAP*        THRU 0290-1000-BUILD-PARM-INFO-X.
SESCAP*    MOVE RUSCL-MAX-SESN-NUM TO L0290-INPUT-NUMBER.
SESCAP*    MOVE 0                     TO  L0290-PRECISION.
SESCAP*    MOVE 'N'                   TO L0290-SIGN-IND
SESCAP*    MOVE LENGTH OF MIR-MAX-SESN-NUM TO L0290-MAX-OUT-LEN.
SESCAP*    PERFORM  0290-1000-NUMERIC-FORMAT
SESCAP*        THRU 0290-1000-NUMERIC-FORMAT-X.
SESCAP*    MOVE L0290-OUTPUT-DATA     TO  MIR-MAX-SESN-NUM.
SESCAP     MOVE RUSCL-MAX-SESN-NUM    TO  MIR-MAX-SESN-NUM.
SESCAP*
       9200-MOVE-RECORD-TO-SCREEN-X.
           EXIT.
      /
      *--------------------------
       9300-SETUP-MSIN-REFERENCE.
      *--------------------------
      *
           MOVE SPACES                TO WGLOB-MSIN-REFERENCE.
           MOVE WGLOB-COMPANY-CODE    TO WGLOB-REF-COMPANY-CODE.
      *
       9300-SETUP-MSIN-REFERENCE-X.
           EXIT.
