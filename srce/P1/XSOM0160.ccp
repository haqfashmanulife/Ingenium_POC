       PROCEDURE DIVISION USING WGLOB-GLOBAL-AREA
53-062                          MIR-PARM-AREA.


      *--------------
       0000-MAINLINE.
      *--------------
      *
           SET MIR-RETRN-OK              TO  TRUE.

557708     PERFORM  ABND-1000-HANDLE-ABEND
557708         THRU ABND-1000-HANDLE-ABEND-X.

           PERFORM  INIT-1000-INITIALIZE
               THRU INIT-1000-INITIALIZE-X.
      *
           PERFORM  2000-PROCESS-REQUEST
               THRU 2000-PROCESS-REQUEST-X.
      *
           PERFORM  EXIT-1000-FINALIZE
               THRU EXIT-1000-FINALIZE-X.

           GOBACK.

       0000-MAINLINE-X.
           EXIT.
      /
      *--------------------
       2000-PROCESS-REQUEST.
      *--------------------

           PERFORM  9300-SETUP-MSIN-REFERENCE
               THRU 9300-SETUP-MSIN-REFERENCE-X.

           MOVE MIR-BUS-FCN-ID        TO WS-BUS-FCN-ID.
      *
      *    PROCESS SCREEN FUNCTIONS
      *
54-001     EVALUATE TRUE

54-001         WHEN WS-BUS-FCN-RETRIEVE
                  PERFORM  2100-PROCESS-RETRIEVE
                      THRU 2100-PROCESS-RETRIEVE-X

54-001         WHEN WS-BUS-FCN-CREATE
                  PERFORM  2200-PROCESS-CREATE
                      THRU 2200-PROCESS-CREATE-X

54-001         WHEN WS-BUS-FCN-UPDATE
                  PERFORM  2300-PROCESS-UPDATE
                      THRU 2300-PROCESS-UPDATE-X

54-001         WHEN WS-BUS-FCN-DELETE
                  PERFORM  2400-PROCESS-DELETE
                      THRU 2400-PROCESS-DELETE-X

54-001         WHEN WS-BUS-FCN-LIST
                  PERFORM  2500-PROCESS-LIST
                      THRU 2500-PROCESS-LIST-X

               WHEN OTHER
      *MSG: INVALID BUSINESS FUNCTION @1 FOR PROGRAM @2
                    SET MIR-RETRN-INVALD-RQST     TO  TRUE
                    MOVE 'XS00000237' TO  WGLOB-MSG-REF-INFO
                    MOVE MIR-BUS-FCN-ID
                                      TO WGLOB-MSG-PARM (1)
                    MOVE 'XSOM0160'   TO WGLOB-MSG-PARM (2)
                    PERFORM  0260-1000-GENERATE-MESSAGE
                        THRU 0260-1000-GENERATE-MESSAGE-X

54-001     END-EVALUATE.
      *
       2000-PROCESS-REQUEST-X.
           EXIT.
      /
      *---------------------
       2100-PROCESS-RETRIEVE.
      *---------------------
      *
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.

           PERFORM  USCL-1000-READ
               THRU USCL-1000-READ-X.
      *
           IF  WUSCL-IO-OK
               PERFORM  9200-MOVE-RECORD-TO-SCREEN
                   THRU 9200-MOVE-RECORD-TO-SCREEN-X
           ELSE
               PERFORM  9100-BLANK-DATA-FIELDS
                   THRU 9100-BLANK-DATA-FIELDS-X
               MOVE WUSCL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000001'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.
      *
       2100-PROCESS-RETRIEVE-X.
           EXIT.
      /
      *--------------------
       2200-PROCESS-CREATE.
      *--------------------
      *
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.

           PERFORM  USCL-1000-READ
               THRU USCL-1000-READ-X.
      *
           IF  WUSCL-IO-OK
               PERFORM  9200-MOVE-RECORD-TO-SCREEN
                   THRU 9200-MOVE-RECORD-TO-SCREEN-X
               MOVE WUSCL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000003'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               GO TO 2200-PROCESS-CREATE-X
54-001     END-IF.
      *
           PERFORM  2210-CREATE-EDITS
               THRU 2210-CREATE-EDITS-X.
      *
           IF  WGLOB-MSG-ERROR-SW > ZERO
               GO TO 2200-PROCESS-CREATE-X
54-001     END-IF.
      *
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.
           PERFORM  USCL-1000-CREATE
               THRU USCL-1000-CREATE-X.
           PERFORM  USCL-1000-WRITE
               THRU USCL-1000-WRITE-X.
           PERFORM  9200-MOVE-RECORD-TO-SCREEN
               THRU 9200-MOVE-RECORD-TO-SCREEN-X.
      *
       2200-PROCESS-CREATE-X.
           EXIT.
      *
      *------------------
       2210-CREATE-EDITS.
      *------------------
      *
           IF  MIR-SECUR-CLAS-ID = SPACE
               MOVE 'XS01600005'      TO WGLOB-MSG-REF-INFO
557660         PERFORM 0260-1000-GENERATE-MESSAGE
557660            THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.
      *
       2210-CREATE-EDITS-X.
           EXIT.
      /
      *----------------------
       2300-PROCESS-UPDATE.
      *----------------------
      *
           MOVE MIR-SECUR-CLAS-ID     TO WUSCL-SECUR-CLAS-ID.

           PERFORM  USCL-1000-READ-FOR-UPDATE
               THRU USCL-1000-READ-FOR-UPDATE-X.

           IF  WUSCL-IO-NOT-FOUND
               PERFORM  9100-BLANK-DATA-FIELDS
                   THRU 9100-BLANK-DATA-FIELDS-X
               MOVE WUSCL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000006'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               GO TO 2300-PROCESS-UPDATE-X
54-001     END-IF.

           PERFORM  2330-UPDATE-EDITS
               THRU 2330-UPDATE-EDITS-X.

           PERFORM  USCL-2000-REWRITE
               THRU USCL-2000-REWRITE-X.

           IF  WGLOB-MSG-ERROR-SW > ZERO
               MOVE 'XS00000008'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
           ELSE
               MOVE 'XS00000007'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.
      *
       2300-PROCESS-UPDATE-X.
           EXIT.
      /
      *--------------------
       2330-UPDATE-EDITS.
      *--------------------
      *
554712*    IF  MIR-ETBL-DESC-TXT NOT = SPACE
554712*        PERFORM  2331-EDIT-SEC-CLASS-DESC
554712*            THRU 2331-EDIT-SEC-CLASS-DESC-X
554712*    ELSE
554712*        MOVE RUSCL-SECUR-DESC-TXT     TO MIR-ETBL-DESC-TXT
554712*    END-IF.
012614*
012624*    IF  MIR-MSG-SECUR-CLAS-CD NOT = SPACE
012614*        PERFORM  2332-EDIT-MSG-CLASS
012614*            THRU 2332-EDIT-MSG-CLASS-X
012614*    ELSE
012614*        MOVE RUSCL-MSG-SECUR-CLAS-CD
012614*                               TO MIR-MSG-SECUR-CLAS-CD
012624*    END-IF.
      *
           IF  MIR-SECUR-CNFD-ACCS-CD NOT = SPACE
               PERFORM  2333-EDIT-CONFIDENTIAL-IND
                   THRU 2333-EDIT-CONFIDENTIAL-IND-X
           ELSE
               MOVE RUSCL-SECUR-CNFD-ACCS-CD
                                      TO MIR-SECUR-CNFD-ACCS-CD
54-001     END-IF.
      *
           IF  MIR-SECUR-LVL-CD NOT = SPACE
               PERFORM  2334-EDIT-CLASS-LEVEL-IND
                   THRU 2334-EDIT-CLASS-LEVEL-IND-X
           ELSE
               MOVE RUSCL-SECUR-LVL-CD               TO MIR-SECUR-LVL-CD
54-001     END-IF.
      *
012624*    IF  MIR-SECUR-APPL-USE-TXT NOT = SPACE
012624     IF  MIR-SECUR-CLAS-UWG-AMT NOT = SPACES
012624*        PERFORM  2335-EDIT-APPL-DEFN
012624*            THRU 2335-EDIT-APPL-DEFN-X
012624         PERFORM  2335-EDIT-SECUR-CLAS-UWG-AMT
012624             THRU 2335-EDIT-SECUR-CLAS-UWG-AMT-X
           ELSE
557659*        MOVE RUSCL-SECUR-APPL-DEFN-CD TO MIR-SECUR-APPL-USE-TXT
012624*        MOVE RUSCL-SECUR-APPL-USE-TXT
012624*                               TO MIR-SECUR-APPL-USE-TXT
012624         PERFORM  0290-1000-BUILD-PARM-INFO
012624             THRU 0290-1000-BUILD-PARM-INFO-X
012624         COMPUTE L0290-INPUT-NUMBER = RUSCL-SECUR-CLAS-UWG-AMT
012624                                    * 100
012624         MOVE 2                 TO L0290-PRECISION
012624         MOVE LENGTH OF MIR-SECUR-CLAS-UWG-AMT
012624                                TO L0290-MAX-OUT-LEN
012624         PERFORM  0290-1000-NUMERIC-FORMAT
012624             THRU 0290-1000-NUMERIC-FORMAT-X
012624         MOVE L0290-OUTPUT-DATA TO  MIR-SECUR-CLAS-UWG-AMT
012624     END-IF.
      *
012624     IF MIR-SECUR-CLAS-MAX-AMT NOT = SPACE
012624         PERFORM  2336-EDIT-SECUR-CLAS-MAX-AMT
012624             THRU 2336-EDIT-SECUR-CLAS-MAX-AMT-X
012624     ELSE
012624         PERFORM  0290-1000-BUILD-PARM-INFO
012624             THRU 0290-1000-BUILD-PARM-INFO-X
012624         COMPUTE L0290-INPUT-NUMBER = RUSCL-SECUR-CLAS-MAX-AMT
012624                                    * 100
012624         MOVE +2                    TO L0290-PRECISION
012624         MOVE LENGTH OF MIR-SECUR-CLAS-MAX-AMT
012624                                    TO L0290-MAX-OUT-LEN
012624         PERFORM  0290-1000-NUMERIC-FORMAT
012624             THRU 0290-1000-NUMERIC-FORMAT-X
012624         MOVE L0290-OUTPUT-DATA TO MIR-SECUR-CLAS-MAX-AMT
012624     END-IF.
      *
012624     IF MIR-CTL-ACCT-ACCS-IND NOT = SPACE
012624         PERFORM  2337-EDIT-CTL-ACCT-ACCS-IND
012624             THRU 2337-EDIT-CTL-ACCT-ACCS-IND-X
012624     ELSE
012624         MOVE RUSCL-CTL-ACCT-ACCS-IND
012624                                TO MIR-CTL-ACCT-ACCS-IND
012624     END-IF.
      *
           MOVE RUSCL-SECUR-USER-CTR  TO MIR-SECUR-USER-CTR.
      *
SESCAP     IF MIR-SESN-CTL-IND NOT = SPACES
SESCAP        PERFORM  2338-EDIT-SESN-CTL-IND
SESCAP            THRU 2338-EDIT-SESN-CTL-IND-X
SESCAP     ELSE
SESCAP        MOVE RUSCL-SESN-CTL-IND   TO MIR-SESN-CTL-IND
SESCAP     END-IF.
SESCAP     IF MIR-MAX-SESN-NUM NOT = SPACES
SESCAP        PERFORM  2339-EDIT-MAX-SESN-NUM
SESCAP            THRU 2339-EDIT-MAX-SESN-NUM-X
SESCAP     ELSE
SESCAP        MOVE RUSCL-MAX-SESN-NUM TO MIR-MAX-SESN-NUM
SESCAP     END-IF.
      *
       2330-UPDATE-EDITS-X.
           EXIT.
      /
