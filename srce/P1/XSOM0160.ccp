012624*        PERFORM  0260-1000-GENERATE-MESSAGE
012624*            THRU 0260-1000-GENERATE-MESSAGE-X
012624*    END-IF.
012624*
012624*2332-EDIT-MSG-CLASS-X.
012624*    EXIT.
      /
      *---------------------------
       2333-EDIT-CONFIDENTIAL-IND.
      *---------------------------
      *
           IF  MIR-SECUR-CNFD-ACCS-CD = EBLCH-BLANK-FIELD-CHAR
               MOVE SPACES            TO MIR-SECUR-CNFD-ACCS-CD
54-001     END-IF.

           MOVE MIR-SECUR-CNFD-ACCS-CD    TO WS-CONFIDENTIAL-ACCESS-IND.

           IF  WS-CONFIDENTIAL-ACCESS-VALID
               MOVE MIR-SECUR-CNFD-ACCS-CD
                                      TO RUSCL-SECUR-CNFD-ACCS-CD
           ELSE
               MOVE 'XS01600002'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.

       2333-EDIT-CONFIDENTIAL-IND-X.
           EXIT.
      /
      *--------------------------
       2334-EDIT-CLASS-LEVEL-IND.
      *--------------------------
      *
           IF  MIR-SECUR-LVL-CD = EBLCH-BLANK-FIELD-CHAR
               MOVE SPACES            TO MIR-SECUR-LVL-CD
54-001     END-IF.
      *
           MOVE MIR-SECUR-LVL-CD      TO WS-SECURITY-CLASS-LEVEL-IND.

           IF  WS-SECURITY-CLASS-LEVEL-VALID
               MOVE MIR-SECUR-LVL-CD  TO RUSCL-SECUR-LVL-CD
           ELSE
               MOVE 'XS01600003'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.
      *
       2334-EDIT-CLASS-LEVEL-IND-X.
           EXIT.
