013578*        MOVE SPACES            TO MIR-DV-APPL-ID-TXT
013578*    END-IF.

           PERFORM  9220-MOVE-CTRY-AND-CURR
               THRU 9220-MOVE-CTRY-AND-CURR-X
               VARYING SUB1 FROM 1 BY 1
               UNTIL   SUB1 > 5.

           MOVE RAPPL-APPL-ASCL-REL-CTR
                                      TO WS-DISPLAY-NUM.
           MOVE WS-DISPLAY-NUM        TO MIR-APPL-ASCL-REL-CTR.

       9200-MOVE-RECORD-TO-SCREEN-X.
           EXIT.

      *------------------------
       9220-MOVE-CTRY-AND-CURR.
      *------------------------

           MOVE RAPPL-APPL-CTRY-CD (SUB1)
013578                              TO MIR-APPL-CTRY-1-CD-T (SUB1).
013578*                             TO MIR-APPL-CTRY-5-CD-T (SUB1).
           PERFORM  9222-MOVE-CURR
013578         THRU 9222-MOVE-CURR-X.
013578*        THRU 9222-MOVE-CURR-X
013578*        VARYING SUB2 FROM 1 BY 1
013578*        UNTIL   SUB2 > 5.

       9220-MOVE-CTRY-AND-CURR-X.
           EXIT.

      *---------------
       9222-MOVE-CURR.
      *---------------

013578*    MOVE RAPPL-APPL-CRCY-CD     (SUB1 SUB2)
013578*                               TO
013578*         MIR-APPL-CRCY-5-5-CD-T (SUB1 SUB2).

013578     MOVE RAPPL-APPL-CRCY-CD   (SUB1 1)
013578                                TO
013578          MIR-APPL-CRCY-1-1-CD-T   (SUB1).
013578     MOVE RAPPL-APPL-CRCY-CD   (SUB1 2)
013578                                TO
013578          MIR-APPL-CRCY-2-1-CD-T   (SUB1).
013578     MOVE RAPPL-APPL-CRCY-CD   (SUB1 3)
013578                                TO
013578          MIR-APPL-CRCY-3-1-CD-T   (SUB1).
013578     MOVE RAPPL-APPL-CRCY-CD   (SUB1 4)
013578                                TO
013578          MIR-APPL-CRCY-4-1-CD-T   (SUB1).
013578     MOVE RAPPL-APPL-CRCY-CD   (SUB1 5)
013578                                TO
013578          MIR-APPL-CRCY-5-1-CD-T   (SUB1).


       9222-MOVE-CURR-X.
           EXIT.

      *--------------------------
       9300-SETUP-MSIN-REFERENCE.
      *--------------------------

           MOVE SPACES                TO WGLOB-MSIN-REFERENCE.
           MOVE WGLOB-COMPANY-CODE    TO WGLOB-REF-COMPANY-CODE.

       9300-SETUP-MSIN-REFERENCE-X.
           EXIT.

       COPY XCPPINIT.

       COPY XCPPEXIT.

554712 COPY XCPEAPPL.

       COPY XCPECOMP.

008453*COPY XCPECNTY.
008453 COPY XCPNCTRY.

008455*COPY XCPECURR.
008455 COPY XCPNCRCY.

       COPY XCCL0260.

013578*COPY XCPPMEXT.

557708*COPY XCCPHNDL.
557708 COPY XCCPABND.
       COPY XCCP0030.
      *****************************************************************
      *  FILE I/O PROCESS MODULES
      *****************************************************************
013578*COPY XCPBAPPL.

       COPY XCPNAPPL.

       COPY XCPUAPPL.

       COPY XCPAAPPL.

       COPY XCPCAPPL.

       COPY XCPXAPPL.

       COPY XCPNXTAB.

      *****************************************************************
      **                 END OF PROGRAM XSOM0150                     **
      *****************************************************************
