      *-----------------------------
       2355-CHK-DUPLICATE-CTRY-CURR.
      *-----------------------------

013578*    IF MIR-APPL-CTRY-5-CD-T (CTRY-IDX1) = SPACES
013578     IF MIR-APPL-CTRY-1-CD-T (CTRY-IDX1) = SPACES
               GO TO 2355-CHK-DUPLICATE-CTRY-CURR-X
54-001     END-IF.

54-001     COMPUTE CTRY-IDX2 = CTRY-IDX1 + 1.

           IF CTRY-IDX2 > 5
54-001         CONTINUE
           ELSE
               PERFORM  2360-CHK-DUP-CTRY
                   THRU 2360-CHK-DUP-CTRY-X
                   VARYING CTRY-IDX2 FROM CTRY-IDX2 BY 1
                   UNTIL CTRY-IDX2 > 5

54-001     END-IF.

           PERFORM  2365-CHK-DUP-CURR-LIST
               THRU 2365-CHK-DUP-CURR-LIST-X
               VARYING CURR-IDX1 FROM 1 BY 1
               UNTIL CURR-IDX1 > 5.

       2355-CHK-DUPLICATE-CTRY-CURR-X.
           EXIT.

