013578*        THRU APPL-1000-BROWSE-X.
013578*
013578*    IF WAPPL-IO-EOF
013578*        MOVE 'XS00000034'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*        GO TO 2500-PROCESS-LIST-X
013578*    END-IF.
013578*
013578*    PERFORM  APPL-2000-READ-NEXT
013578*        THRU APPL-2000-READ-NEXT-X.
013578*
013578*    IF WAPPL-IO-EOF
013578*        MOVE 'XS00000025'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*        GO TO 2500-PROCESS-LIST-X
013578*    END-IF.
013578*
013578*    MOVE +1                    TO WS-SUB.
013578*    PERFORM  2510-PROCESS-LIST-READ
013578*        THRU 2510-PROCESS-LIST-READ-X
013578*        UNTIL WS-SUB > WS-MAX-BROWSE-LINES
013578*        OR    WAPPL-IO-EOF.
013578*
013578*    IF WAPPL-IO-EOF
013578*        MOVE 'XS00000025'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*    ELSE
013578*        SET WGLOB-MORE-DATA-EXISTS TO TRUE
013578*        MOVE 'XS00000014'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*    END-IF.
013578*
013578*    PERFORM  APPL-3000-END-BROWSE
013578*        THRU APPL-3000-END-BROWSE-X.
013578*
013578*2500-PROCESS-LIST-X.
013578*    EXIT.
013578*
013578*-------------------------
013578*2510-PROCESS-LIST-READ.
013578*-------------------------
013578*
013578*    PERFORM  2520-DISPLAY-LINE
013578*        THRU 2520-DISPLAY-LINE-X
013578*        VARYING SUB1 FROM +1 BY +1
013578*        UNTIL   SUB1 > +5
013578*        OR      WS-SUB > WS-MAX-BROWSE-LINES.
013578*
013578*    IF WS-SUB > WS-MAX-BROWSE-LINES
013578*        MOVE MIR-APPL-ID-T (WS-MAX-BROWSE-LINES) TO MIR-APPL-ID
013578*        MOVE MIR-CO-ID-T (WS-MAX-BROWSE-LINES) TO MIR-CO-ID
013578*        MOVE MIR-APPL-ID-T (WS-MAX-BROWSE-LINES)
013578*                               TO MIR-APPL-ID
013578*        MOVE MIR-CO-ID-T (WS-MAX-BROWSE-LINES)
013578*                               TO MIR-CO-ID
013578*    ELSE
013578*        PERFORM  APPL-2000-READ-NEXT
013578*            THRU APPL-2000-READ-NEXT-X
013578*    END-IF.
013578*
013578*2510-PROCESS-LIST-READ-X.
013578*    EXIT.
013578*
013578*------------------
013578*2520-DISPLAY-LINE.
013578*------------------
013578*
013578*    IF RAPPL-APPL-CTRY-CD (SUB1) > SPACE
013578*    OR SUB1 = +1
013578*        MOVE RAPPL-APPL-ID     TO MIR-APPL-ID-T  (WS-SUB)
013578*        MOVE RAPPL-CO-ID       TO MIR-CO-ID-T    (WS-SUB)
013578*        MOVE RAPPL-APPL-ID     TO MIR-APPL-ID-T  (WS-SUB)
013578*        MOVE RAPPL-CO-ID       TO MIR-CO-ID-T    (WS-SUB)
013578*        MOVE RAPPL-APPL-CTRY-CD (SUB1)
013578*                            TO MIR-APPL-CTRY-10-CD-T (WS-SUB)
013578*        MOVE RAPPL-APPL-CRCY-CD  (SUB1 1)
013578*                         TO MIR-APPL-CRCY-10-5-CD-T (WS-SUB 1)
013578*        MOVE RAPPL-APPL-CRCY-CD  (SUB1 2)
013578*                         TO MIR-APPL-CRCY-10-5-CD-T (WS-SUB 2)
013578*        MOVE RAPPL-APPL-CRCY-CD  (SUB1 3)
013578*                         TO MIR-APPL-CRCY-10-5-CD-T (WS-SUB 3)
013578*        MOVE RAPPL-APPL-CRCY-CD  (SUB1 4)
013578*                         TO MIR-APPL-CRCY-10-5-CD-T (WS-SUB 4)
013578*        MOVE RAPPL-APPL-CRCY-CD  (SUB1 5)
013578*                         TO MIR-APPL-CRCY-10-5-CD-T (WS-SUB 5)
013578*        ADD +1                               TO WS-SUB
013578*    END-IF.
