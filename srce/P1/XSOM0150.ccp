       PROCEDURE DIVISION USING WGLOB-GLOBAL-AREA
53-062                          MIR-PARM-AREA.

      *--------------
       0000-MAINLINE.
      *--------------

           SET MIR-RETRN-OK                   TO  TRUE.

015648     INSPECT MIR-PARM-AREA REPLACING ALL '*' BY ' '.

557708     PERFORM  ABND-1000-HANDLE-ABEND
557708         THRU ABND-1000-HANDLE-ABEND-X.

           PERFORM  INIT-1000-INITIALIZE
               THRU INIT-1000-INITIALIZE-X.

           PERFORM  2000-PROCESS-REQUEST
               THRU 2000-PROCESS-REQUEST-X.

           PERFORM  EXIT-1000-FINALIZE
               THRU EXIT-1000-FINALIZE-X.


           GOBACK.

       0000-MAINLINE-X.
           EXIT.

      *--------------------------
       2000-PROCESS-REQUEST.
      *--------------------------

           PERFORM  9300-SETUP-MSIN-REFERENCE
              THRU  9300-SETUP-MSIN-REFERENCE-X.

           MOVE MIR-BUS-FCN-ID        TO WS-BUS-FCN-ID.

      *
      *    PROCESS SCREEN FUNCTIONS
      *

54-001     EVALUATE TRUE

54-001         WHEN WS-BUS-FCN-RETRIEVE
                    PERFORM  2100-PROCESS-RETRIEVE
                        THRU 2100-PROCESS-RETRIEVE-X

54-001         WHEN WS-BUS-FCN-CREATE
                    PERFORM  2200-PROCESS-CREATE
                        THRU 2200-PROCESS-CREATE-X

54-001         WHEN WS-BUS-FCN-UPDATE
                    PERFORM  2300-PROCESS-UPDATE
                        THRU 2300-PROCESS-UPDATE-X

54-001         WHEN WS-BUS-FCN-DELETE
                    PERFORM  2400-PROCESS-DELETE
                        THRU 2400-PROCESS-DELETE-X

013578*        WHEN WS-BUS-FCN-LIST
013578*             PERFORM  2500-PROCESS-LIST
013578*                 THRU 2500-PROCESS-LIST-X

               WHEN OTHER
      *MSG: INVALID BUSINESS FUNCTION @1 FOR PROGRAM @2
                    MOVE 'XS00000237' TO  WGLOB-MSG-REF-INFO
                    MOVE MIR-BUS-FCN-ID
                                      TO WGLOB-MSG-PARM (1)
                    MOVE 'XSOM0150'   TO WGLOB-MSG-PARM (2)
                    PERFORM  0260-1000-GENERATE-MESSAGE
                        THRU 0260-1000-GENERATE-MESSAGE-X
                    SET MIR-RETRN-INVALD-RQST TO TRUE

54-001     END-EVALUATE.

       2000-PROCESS-REQUEST-X.
           EXIT.

      *---------------------
       2100-PROCESS-RETRIEVE.
      *---------------------

013578*    MOVE MIR-APPL-ID           TO WAPPL-APPL-ID.
013578     MOVE WGLOB-COMPANY-CODE    TO WS-CO-ID.
013578     MOVE MIR-CO-ID             TO WGLOB-COMPANY-CODE.
           MOVE MIR-CO-ID             TO WAPPL-CO-ID.
           PERFORM  APPL-1000-READ
               THRU APPL-1000-READ-X.
013578     MOVE WS-CO-ID              TO WGLOB-COMPANY-CODE.

           IF WAPPL-IO-OK
               PERFORM  9200-MOVE-RECORD-TO-SCREEN
                   THRU 9200-MOVE-RECORD-TO-SCREEN-X
           ELSE
               PERFORM  9100-BLANK-DATA-FIELDS
                  THRU  9100-BLANK-DATA-FIELDS-X
               MOVE WAPPL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000001'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               SET MIR-RETRN-RQST-FAILED         TO  TRUE
54-001     END-IF.

       2100-PROCESS-RETRIEVE-X.
           EXIT.

      *--------------------
       2200-PROCESS-CREATE.
      *--------------------

013578*    MOVE MIR-APPL-ID           TO WAPPL-APPL-ID.
013578     MOVE WGLOB-COMPANY-CODE    TO WS-CO-ID.
013578     MOVE MIR-CO-ID             TO WGLOB-COMPANY-CODE.
           MOVE MIR-CO-ID             TO WAPPL-CO-ID.
           PERFORM  APPL-1000-READ
               THRU APPL-1000-READ-X.
013578     MOVE WS-CO-ID              TO WGLOB-COMPANY-CODE.

           IF WAPPL-IO-OK
               PERFORM  9200-MOVE-RECORD-TO-SCREEN
                   THRU 9200-MOVE-RECORD-TO-SCREEN-X
               MOVE WAPPL-KEY         TO WGLOB-MSG-PARM (1)
               MOVE 'XS00000003'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
               SET MIR-RETRN-RQST-FAILED           TO  TRUE
               GO TO 2200-PROCESS-CREATE-X
54-001     END-IF.

           PERFORM  2210-CREATE-EDITS
               THRU 2210-CREATE-EDITS-X.

           IF WGLOB-MSG-ERROR-SW > ZERO
               SET MIR-RETRN-RQST-FAILED          TO  TRUE
               GO TO 2200-PROCESS-CREATE-X
54-001     END-IF.

013578*    MOVE MIR-APPL-ID           TO WAPPL-APPL-ID.
013578     MOVE WGLOB-COMPANY-CODE    TO WS-CO-ID.
013578     MOVE MIR-CO-ID             TO WGLOB-COMPANY-CODE.
           MOVE MIR-CO-ID             TO WAPPL-CO-ID.
           PERFORM  APPL-1000-CREATE
               THRU APPL-1000-CREATE-X.
           PERFORM  APPL-1000-WRITE
               THRU APPL-1000-WRITE-X.
           PERFORM  9200-MOVE-RECORD-TO-SCREEN
               THRU 9200-MOVE-RECORD-TO-SCREEN-X.
013578     MOVE WS-CO-ID              TO WGLOB-COMPANY-CODE.

       2200-PROCESS-CREATE-X.
           EXIT.

      *------------------
       2210-CREATE-EDITS.
      *------------------

013578*    IF MIR-APPL-ID = SPACE
013578*        MOVE 'XS01500001'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*    END-IF.

           MOVE MIR-CO-ID             TO WXTAB-ETBL-VALU-ID.
           PERFORM  COMP-1000-EDIT-COMPANY
               THRU COMP-1000-EDIT-COMPANY-X.

           IF NOT WXTAB-IO-OK
               MOVE 'XS01500002'      TO WGLOB-MSG-REF-INFO
               PERFORM  0260-1000-GENERATE-MESSAGE
                   THRU 0260-1000-GENERATE-MESSAGE-X
54-001     END-IF.

013578*    IF WGLOB-MSG-ERROR-SW > ZERO
013578*        GO TO 2210-CREATE-EDITS-X
013578*    END-IF.
013578*
013578*    MOVE LOW-VALUES            TO WAPPL-KEY.
013578*    MOVE HIGH-VALUES           TO WAPPL-ENDBR-KEY.
013578*    PERFORM  APPL-1000-BROWSE
013578*        THRU APPL-1000-BROWSE-X.
013578*
013578*    IF WAPPL-IO-EOF
013578*        GO TO 2210-CREATE-EDITS-X
013578*    END-IF.
013578*
013578*    PERFORM  APPL-2000-READ-NEXT
013578*        THRU APPL-2000-READ-NEXT-X.
013578*    MOVE ZERO                  TO WS-APPL-COMP-COUNT.
013578*
013578*    PERFORM  2212-COUNT-APPL-COMP
013578*        THRU 2212-COUNT-APPL-COMP-X
013578*        UNTIL WAPPL-IO-EOF
013578*        OR    WS-APPL-COMP-COUNT = WS-MAX-APPL-COMP.
013578*
013578*
013578*    PERFORM  APPL-3000-END-BROWSE
013578*        THRU APPL-3000-END-BROWSE-X.
013578*
013578*    IF WS-APPL-COMP-COUNT = WS-MAX-APPL-COMP
013578*        MOVE 'XS01500010'      TO WGLOB-MSG-REF-INFO
013578*        PERFORM  0260-1000-GENERATE-MESSAGE
013578*            THRU 0260-1000-GENERATE-MESSAGE-X
013578*    END-IF.

       2210-CREATE-EDITS-X.
           EXIT.

